{
  "openclawHome": "${OPENCLAW_HOME}",
  "database": {
    "path": "${OPENCLAW_HOME}/orchestrator/orchestrator.db"
  },
  "discord": {
    "approval": {
      "mode": "same_thread",
      "keywords": [
        "approve",
        "/approve",
        "lgtm"
      ],
      "fetchCommand": [
        "openclaw",
        "message",
        "read",
        "--channel",
        "discord",
        "--target",
        "{thread_id}",
        "--limit",
        "{limit}"
      ]
    },
    "notifications": {
      "milestones": true
    }
  },
  "merge": {
    "autoMerge": false,
    "requireGreenChecks": true,
    "requireApproval": true
  },
  "routing": {
    "map": {
      "code": "chad",
      "content": "halbert"
    },
    "allowTargetOverride": true,
    "agentAutoDiscovery": true,
    "devFallbackAgent": "chad"
  },
  "scheduler": {
    "linux": {
      "mode": "systemd-timer",
      "service": "rei-orchestrator-worker.service",
      "timer": "rei-orchestrator-worker.timer",
      "intervalSeconds": 60
    },
    "macos": {
      "mode": "launchd",
      "label": "com.rei.orchestrator.worker",
      "plist": "~/Library/LaunchAgents/com.rei.orchestrator.worker.plist",
      "intervalSeconds": 60
    }
  },
  "github": {
    "repo": "owner/repo",
    "baseBranch": "main",
    "requirePrForCodeTasks": true
  },
  "screenshot": {
    "command": "npx playwright screenshot {url} {output}"
  },
  "runtime": {
    "openclawDispatch": {
      "command": [
        "openclaw",
        "agent",
        "--agent",
        "{agent}",
        "--session-id",
        "orchestrator:{run_id}",
        "--message",
        "{dispatch_message}",
        "--json"
      ]
    }
  }
}
